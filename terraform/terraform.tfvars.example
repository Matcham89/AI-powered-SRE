# Copy to terraform.tfvars (gitignored) and fill in values.
#
# Port-forward before running terraform:
#   kubectl port-forward -n authentik svc/authentik-server 9000:80
#
# Bootstrap token:
#   SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt \
#   sops --decrypt platform/auth/authentik-secret.enc.yaml | grep BOOTSTRAP_TOKEN

authentik_url   = "http://localhost:9000"
authentik_token = "PASTE_BOOTSTRAP_TOKEN_HERE"

# Grafana secret: decrypt observability-secrets.enc.yaml and look for grafana-oidc-secret.client_secret
# sops --decrypt platform/observability/observability-secrets.enc.yaml | grep -A2 grafana-oidc
grafana_client_secret  = "PASTE_FROM_OBSERVABILITY_SECRETS"

# Temporal secret: decrypt apps/temporal/oauth2-proxy-secret.enc.yaml
# sops --decrypt apps/temporal/oauth2-proxy-secret.enc.yaml | grep client-secret
temporal_client_secret = "f7d483bd9f9319744bddeae00c7d92715ffd84ec8ae064342a9e8304d2e31128"

# ArgoCD OIDC client secret — choose any strong random value, then patch into argocd-secret:
#   kubectl patch secret argocd-secret -n argocd \
#     -p '{"data":{"oidc.authentik.clientSecret":"<base64-of-secret>"}}'
argocd_client_secret = "CHOOSE_A_STRONG_SECRET"

# Set a strong password for the demo-user account in Authentik
admin_password = "CHOOSE_A_STRONG_PASSWORD"
