# AI-Powered SRE Platform — Environment Variables
# Copy to .env and populate. Never commit .env.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env

# ─── Age Encryption ────────────────────────────────────────────────────────────
# Path to your Age private key file (default location used by sops)
SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt

# ─── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with: repo (read), issues (write)
# This gets SOPS-encrypted into cluster/registry/repo-credentials.enc.yaml
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repo URL (no trailing slash)
GITHUB_REPO_URL=https://github.com/Matcham89/AI-powered-SRE

# ─── Anthropic ─────────────────────────────────────────────────────────────────
# Claude API key for kagent (AI SRE agent)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Domain ────────────────────────────────────────────────────────────────────
# Base domain for all platform UIs (e.g. local, example.com)
# Services will be exposed as argocd.<DOMAIN>, grafana.<DOMAIN>, etc.
PLATFORM_DOMAIN=local
